# CodeGuard AI Studio - Environment Configuration
#
# Copy this file to ".env" (same folder as pom.xml) and fill in your real key.
# ".env" is already in .gitignore, so it will never be committed.
#
# Get your key from: https://fireworks.ai -> Profile (top right) -> API Keys
FIREWORKS_API_KEY=your-actual-api-key-here

# The model used for scans is NOT set via .env - it's chosen from the
# "AI Core Inference Engine" dropdown on the Settings screen inside the app,
# and is remembered in ~/.codeguard/config.properties.
